<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />

    <!-- Primary Meta Tags -->
    <title>Bandaranayake College Sportmeet 2026 | Live Scores & Results</title>
    <meta
      name="title"
      content="Bandaranayake College Sportmeet 2026 | Live Scores & Results"
    />
    <meta
      name="description"
      content="The official real-time marks board for Bandaranayake College Sportmeet 2026. View live house rankings, athletics results, and sports updates from Bandaranayake College Gampaha."
    />
    <meta
      name="keywords"
      content="Bandaranayake College Sportmeet, bcsports, bc sports site, bc sports, Bandaranayake College Sports, SportMeet 2026, BCG Sportmeet, Inter House Sports Meet Gampaha, Bandaranayake College, Sports Scores, Live Leaderboard"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.bcsports.site/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.bcsports.site/" />
    <meta
      property="og:title"
      content="Bandaranayake College Sportmeet 2026 - Live Daily Updates"
    />
    <meta
      property="og:description"
      content="Stay updated with the latest house rankings and athletics results from Bandaranayake College Sportmeet 2026. Live on bcsports.site."
    />
    <meta
      property="og:image"
      content="https://i.ibb.co/4gJYpW6p/New-Project-5.png"
    />
    <meta property="og:site_name" content="BC Sports Site" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://www.bcsports.site/" />
    <meta
      property="twitter:title"
      content="Bandaranayake College Sportmeet 2026 Live"
    />
    <meta
      property="twitter:description"
      content="Official live updates for Bandaranayake College Sportmeet 2026. View house rankings and moments instantly."
    />
    <meta
      property="twitter:image"
      content="https://i.ibb.co/4gJYpW6p/New-Project-5.png"
    />

    <!-- Schema.org for Google -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SportsEvent",
        "name": "Bandaranayake College Sportmeet 2026",
        "description": "The official real-time marks board for Bandaranayake College Sportmeet 2026. View live house rankings, athletics results, and sports updates from Bandaranayake College Gampaha.",
        "startDate": "2026-01-20T08:00:00+05:30",
        "endDate": "2026-02-28T17:00:00+05:30",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Bandaranayake College Grounds",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Bandaranayake College",
            "addressLocality": "Gampaha",
            "addressRegion": "Western Province",
            "postalCode": "11000",
            "addressCountry": "LK"
          }
        },
        "organizer": {
          "@type": "Organization",
          "name": "Bandaranayake College Coding Club",
          "url": "https://www.bcsports.site",
          "logo": "https://i.ibb.co/4gJYpW6p/New-Project-5.png"
        },
        "image": ["https://i.ibb.co/4gJYpW6p/New-Project-5.png"]
      }
    </script>
    <meta name="author" content="Bandaranayake College Coding Club" />

    <!-- PWA Meta Tags -->
    <meta name="theme-color" content="#080808" />
    <meta name="color-scheme" content="dark" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="SportMeet" />
    <meta name="application-name" content="SportMeet 2026" />
    <meta name="msapplication-TileColor" content="#080808" />
    <meta name="msapplication-tap-highlight" content="no" />

    <!-- Manifest -->
    <link rel="manifest" href="manifest.json" />

    <!-- Icons -->
    <link
      rel="icon"
      type="image/jpeg"
      sizes="32x32"
      href="https://i.ibb.co/p6nRXkvK/Untitled-s1.jpg"
    />
    <link
      rel="icon"
      type="image/jpeg"
      sizes="16x16"
      href="https://i.ibb.co/p6nRXkvK/Untitled-s1.jpg"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="https://i.ibb.co/p6nRXkvK/Untitled-s1.jpg"
    />
    <link
      rel="apple-touch-icon"
      sizes="152x152"
      href="https://i.ibb.co/p6nRXkvK/Untitled-s1.jpg"
    />
    <link
      rel="apple-touch-icon"
      sizes="120x120"
      href="https://i.ibb.co/p6nRXkvK/Untitled-s1.jpg"
    />

    <!-- Performance Optimization: DNS Prefetch & Preconnect -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    <link rel="dns-prefetch" href="https://i.ibb.co" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />

    <!-- Preload Critical Resources -->
    <link rel="preload" href="style.css" as="style" />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap"
      as="style"
    />

    <!-- Stylesheets -->
    <link rel="stylesheet" href="style.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      media="print"
      onload="this.media = 'all'"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Outfit:wght@400;600;700;800&family=Noto+Sans+Sinhala:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Prefetch Data for Instant Loading -->
    <link rel="prefetch" href="data/basic.json" as="fetch" crossorigin />

    <!-- Chart.js Library - Async Load -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"
      async
    ></script>

    <!-- PWA Advanced Features - Deferred -->
    <script src="pwa-features.js" defer></script>
  </head>

  <body>
    <!-- Animated Background Effects -->
    <div class="background">
      <div class="grid-overlay"></div>
      <div class="glow-orb orb-1"></div>
      <div class="glow-orb orb-2"></div>
      <div class="glow-orb orb-3"></div>
    </div>

    <div class="container">
      <header>
        <div class="header-brand">
          <div class="brand-logos">
            <div class="profile-icon"></div>
            <div class="club-icon"></div>
          </div>
          <div class="brand-info">
            <h1 class="header-title">InterHouse Sports 2026</h1>
            <div class="header-subtitle">Live Scores & Rankings</div>
          </div>
        </div>
        <nav class="header-nav" role="navigation" aria-label="Main navigation">
          <a
            class="nav-tab active"
            id="leaderboard-tab"
            title="Leaderboard"
            aria-label="Leaderboard"
          >
            <i class="fas fa-trophy" aria-hidden="true"></i>
            <span>Leaderboard</span>
          </a>
          <a class="nav-tab" id="scores-tab" title="Scores" aria-label="Scores">
            <i class="fas fa-chart-bar" aria-hidden="true"></i>
            <span>Scores</span>
          </a>
          <a
            class="nav-tab"
            id="moments-tab"
            title="Moments"
            aria-label="Moments"
          >
            <i class="fas fa-camera" aria-hidden="true"></i>
            <span>Moments</span>
          </a>
          <a
            class="nav-tab"
            id="leaders-tab"
            title="Leaders"
            aria-label="Leaders"
          >
            <i class="fas fa-users" aria-hidden="true"></i>
            <span>Leaders</span>
          </a>
          <a
            class="nav-tab"
            id="analytics-tab"
            title="Analytics"
            aria-label="Analytics"
          >
            <i class="fas fa-chart-line" aria-hidden="true"></i>
            <span>Analytics</span>
          </a>
        </nav>
      </header>

      <div class="loading-screen" id="loadingScreen">
        <div class="loading-content">
          <div class="loader-rings">
            <div class="ring ring-1"></div>
            <div class="ring ring-2"></div>
            <div class="ring ring-3"></div>
            <div class="ring-core"></div>
          </div>

          <div class="loader-progress-container">
            <div class="loader-progress-bar">
              <div class="loader-progress-fill" id="progressFill"></div>
            </div>
            <div class="loader-percentage" id="progressText">0%</div>
          </div>

          <div class="loading-status" id="loadingStatus">LOADING...</div>
        </div>
      </div>

      <!-- Leaderboard Page -->
      <div id="leaderboard-page" class="page">
        <!-- Leaderboard Hero Header -->
        <div class="page-hero">
          <div class="page-hero-content">
            <span class="page-title-icon"><i class="fas fa-trophy"></i></span>
            <div class="page-hero-text">
              <div class="page-title">Overall House Rankings 2026</div>
              <p class="page-subtitle">
                Live standings and competitive rankings across all sports events
              </p>
            </div>
          </div>
          <div class="page-hero-bg"></div>
        </div>
        <div class="rankings-grid" id="rankings-container"></div>

        <!-- Quick Navigation Cards -->
        <div class="quick-nav-section">
          <div class="analytics-section-divider">
            <div class="divider-line"></div>
            <div class="divider-content">
              <i class="fas fa-university"></i>
              <span>Explore Section</span>
            </div>
            <div class="divider-line"></div>
          </div>

          <div class="quick-nav-grid">
            <div class="nav-card" id="quick-nav-scores">
              <div class="nav-card-icon scores">
                <i class="fas fa-chart-bar"></i>
              </div>
              <div class="nav-card-info">
                <h3>Live Scores</h3>
                <p>View real-time event results</p>
              </div>
              <div class="nav-card-arrow">
                <i class="fas fa-chevron-right"></i>
              </div>
            </div>

            <div class="nav-card" id="quick-nav-moments">
              <div class="nav-card-icon moments">
                <i class="fas fa-camera"></i>
              </div>
